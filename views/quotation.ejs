<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Quotation</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      padding: 20px;
      line-height: 1.4;
      color: #333;
    }

    h1 {
      text-align: center;
      margin-bottom: 20px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    h3 {
      margin-top: 30px;
      margin-bottom: 10px;
    }

    p {
      margin: 2px 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }

    th, td {
      border: 1px solid #333;
      padding: 8px;
      text-align: left;
      vertical-align: top;
    }

    th {
      background-color: #f2f2f2;
      text-align: left;
    }

    .right {
      text-align: right;
    }

    .notes {
      font-style: italic;
      margin-top: 20px;
    }

    .summary-table {
      width: 300px;
      float: right;
      margin-top: 20px;
      border: none;
    }

    .summary-table td {
      border: none;
      padding: 4px 8px;
    }

    .grand-total {
      font-weight: bold;
      font-size: 1.1em;
    }

    /* Optional: page break for large tables */
    .page-break {
      page-break-before: always;
    }
  </style>
</head>
<body>
  <h1>Quotation</h1>

  <p><strong>Quotation ID:</strong> <%= quotation.quotationId %></p>
  <p><strong>Customer:</strong> <%= quotation.customer.name %></p>
  <p><strong>Project Location:</strong> <%= quotation.projectLocation %></p>
  <p><strong>Project Description:</strong> <%= quotation.projectDescription %></p>
  <p><strong>Estimated Start Date:</strong> <%= quotation.estimatedStartDate %></p>
  <p><strong>Estimated Completion Date:</strong> <%= quotation.estimatedCompletionDate %></p>
  <p><strong>Measurement:</strong> <%= quotation.measurement.totalArea %> <%= quotation.measurement.unit %></p>

  <h3>Line Items</h3>
  <table>
    <thead>
      <tr>
        <th>Service</th>
        <th>Description</th>
        <th>Qty</th>
        <th>Rate</th>
        <th>Subtotal</th>
      </tr>
    </thead>
    <tbody>
      <% quotation.lineItems.forEach(item => { %>
      <tr>
        <td><%= item.serviceType %></td>
        <td><%= item.description %></td>
        <td><%= item.qty %> <%= item.unit %></td>
        <td class="right"><%= formatCurrency(item.rate, quotation.currency) %></td>
        <td class="right"><%= formatCurrency(item.subtotal, quotation.currency) %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <table class="summary-table">
    <tr>
      <td>Subtotal:</td>
      <td class="right"><%= formatCurrency(quotation.summary.subTotal, quotation.currency) %></td>
    </tr>
    <tr>
      <td>Tax (<%= quotation.summary.taxRate %> %):</td>
      <td class="right"><%= formatCurrency(quotation.summary.taxAmount, quotation.currency) %></td>
    </tr>
    <tr class="grand-total">
      <td>Grand Total:</td>
      <td class="right"><%= formatCurrency(quotation.summary.grandTotal, quotation.currency) %></td>
    </tr>
  </table>

  <p class="notes">Notes: <%= quotation.notes %></p>

</body>
</html>
